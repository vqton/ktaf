@{
    ViewData["Title"] = "Quản lý thuế";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h4>Quản lý thuế</h4>
                </div>
                <div class="card-body">
                    <ul class="nav nav-tabs" role="tablist">
                        <li class="nav-item">
                            <a class="nav-link active" data-bs-toggle="tab" href="#gtgt">Thuế GTGT</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" data-bs-toggle="tab" href="#tndn">Thuế TNDN</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" data-bs-toggle="tab" href="#tncn">Thuế TNCN</a>
                        </li>
                    </ul>
                    <div class="tab-content mt-3">
                        <div class="tab-pane fade show active" id="gtgt">
                            <div class="alert alert-info">
                                <a asp-controller="Tax" asp-action="GTGT">Xem chi tiết kê khai thuế GTGT</a>
                            </div>
                        </div>
                        <div class="tab-pane fade" id="tndn">
                            <div class="alert alert-info">
                                <a asp-controller="Tax" asp-action="TNDN" asp-route-year="@DateTime.Now.Year" asp-route-month="@DateTime.Now.Month">Xem chi tiết kê khai thuế TNDN</a>
                            </div>
                        </div>
                        <div class="tab-pane fade" id="tncn">
                            <div class="alert alert-info">
                                <a asp-controller="Tax" asp-action="TNCN">Xem biểu thuế lũy tiến TNCN</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
