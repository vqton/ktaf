@model AMS.Application.Accounting.Vouchers.DTOs.VoucherDto

@{
    ViewData["Title"] = "Sửa chứng từ";
}

<div class="page-header">
    <h1 class="page-title">Sửa chứng từ</h1>
    <div class="page-actions">
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Quay lại
        </a>
    </div>
</div>

<div class="page-body">
    <form id="voucherForm" class="acc-ajax-form" 
          asp-action="Edit" asp-controller="Vouchers"
          data-success-msg="Lưu thành công"
          data-redirect="/Vouchers">
        
        @Html.AntiForgeryToken()
        <input type="hidden" name="Id" value="@Model.Id" />
        
        <div class="row g-4 mb-4">
            <div class="col-md-3">
                <label class="form-label">Số chứng từ <span class="required">*</span></label>
                <input type="text" class="form-control font-mono" name="VoucherNo" 
                       value="@Model.VoucherNo" readonly>
            </div>
            <div class="col-md-3">
                <label class="form-label">Ngày CT <span class="required">*</span></label>
                <input type="text" class="form-control date-picker" name="VoucherDate" 
                       value="@Model.VoucherDate.ToString("dd/MM/yyyy")" required>
            </div>
            <div class="col-md-3">
                <label class="form-label">Loại <span class="required">*</span></label>
                <select class="form-select" name="Type" required>
                    <option value="PT" selected="@(Model.Type == "PT")">Phiếu thu</option>
                    <option value="PC" selected="@(Model.Type == "PC")">Phiếu chi</option>
                    <option value="BC" selected="@(Model.Type == "BC")">Biên bản</option>
                    <option value="BN" selected="@(Model.Type == "BN")">Báo Nợ</option>
                    <option value="HB" selected="@(Model.Type == "HB")">Hóa đơn bán</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Trạng thái</label>
                <input type="text" class="form-control" value="@Model.Status" readonly>
            </div>
        </div>

        <div class="row g-4 mb-4">
            <div class="col-md-12">
                <label class="form-label">Diễn giải <span class="required">*</span></label>
                <input type="text" class="form-control" name="Description" 
                       value="@Model.Description" required>
            </div>
        </div>

        <!-- Line Items -->
        <div class="acc-card mb-4">
            <div class="acc-card-header">
                <h5>Chi tiết bút toán</h5>
                <button type="button" class="btn btn-sm btn-outline-primary" id="addLine">
                    <i class="bi bi-plus-lg me-1"></i>Thêm dòng
                </button>
            </div>
            <div class="acc-card-body p-0">
                <div class="table-responsive">
                    <table class="table mb-0" id="journalLines">
                        <thead>
                            <tr>
                                <th style="width:35%">Tài khoản</th>
                                <th>Mô tả dòng</th>
                                <th class="text-end" style="width:150px">Nợ (Debit)</th>
                                <th class="text-end" style="width:150px">Có (Credit)</th>
                                <th style="width:40px"></th>
                            </tr>
                        </thead>
                        <tbody id="linesBody">
                            @if (Model.Lines != null)
                            {
                                @for (int i = 0; i < Model.Lines.Count; i++)
                                {
                                    <tr class="journal-line" data-index="@i">
                                        <td>
                                            <select class="form-select form-select-sm select2-accounts line-account" 
                                                    name="Lines[@i].AccountId" required>
                                                <option value="@Model.Lines[i].AccountId">@Model.Lines[i].AccountCode - @Model.Lines[i].AccountName</option>
                                            </select>
                                        </td>
                                        <td>
                                            <input type="text" class="form-control form-control-sm" 
                                                   name="Lines[@i].Description" value="@Model.Lines[i].Description">
                                        </td>
                                        <td>
                                            <input type="text" class="form-control form-control-sm text-end input-money line-debit" 
                                                   name="Lines[@i].DebitAmount" value="@Model.Lines[i].DebitAmount">
                                        </td>
                                        <td>
                                            <input type="text" class="form-control form-control-sm text-end input-money line-credit" 
                                                   name="Lines[@i].CreditAmount" value="@Model.Lines[i].CreditAmount">
                                        </td>
                                        <td>
                                            <button type="button" class="btn btn-sm btn-link text-danger" onclick="ACC.voucher.removeLine(this)">
                                                <i class="bi bi-x-lg"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                        <tfoot>
                            <tr class="table-total-row">
                                <td colspan="2" class="text-end pe-3">
                                    <div id="balanceIndicator" class="d-flex align-items-center justify-content-end gap-2">
                                        <span class="text-muted small">Chênh lệch:</span>
                                        <span id="differenceAmount" class="font-mono fw-semibold text-danger">—</span>
                                    </div>
                                </td>
                                <td class="text-end font-mono fw-semibold" id="totalDebit">0</td>
                                <td class="text-end font-mono fw-semibold" id="totalCredit">0</td>
                                <td></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>

        <div class="alert" id="balanceAlert" role="alert" style="display:none"></div>

        <div class="d-flex justify-content-between">
            <button type="button" class="btn btn-outline-danger" onclick="confirmDelete()">
                <i class="bi bi-trash me-1"></i>Xóa
            </button>
            <div class="d-flex gap-3">
                <button type="button" class="btn btn-outline-secondary" onclick="window.history.back()">Hủy</button>
                <button type="submit" name="action" value="draft" class="btn btn-outline-primary">
                    <i class="bi bi-save me-1"></i>Lưu nháp
                </button>
            </div>
        </div>
    </form>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Xóa chứng từ</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Bạn có chắc chắn muốn xóa chứng từ này?</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <form asp-action="Delete" asp-controller="Vouchers" method="post">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <button type="submit" class="btn btn-danger">Xóa</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
function confirmDelete() {
    new bootstrap.Modal('#deleteModal').show();
}

$(function() {
    ACC.voucher.calcTotals();
    
    $('#addLine').on('click', function() {
        ACC.voucher.addLine();
    });
});
</script>
}
