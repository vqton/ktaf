@{
    ViewData["Title"] = "Danh Sách Chứng Từ";
}

<div class="card">
    <div class="card-header">
        <h5 class="mb-0">Danh Sách Chứng Từ</h5>
    </div>
    <div class="card-body">
        <div class="row mb-3">
            <div class="col-md-6">
                <a asp-action="Create" class="btn btn-primary">
                    <i class="bi bi-plus-lg me-1"></i> Tạo Chứng Từ Mới
                </a>
            </div>
            <div class="col-md-6">
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input type="text" class="form-control" placeholder="Tìm kiếm..." id="searchInput">
                    <button class="btn btn-outline-secondary" type="button">Tìm</button>
                </div>
            </div>
        </div>
        <table class="table table-striped table-hover" id="vouchersTable">
            <thead>
                <tr>
                    <th><i class="bi bi-hash"></i> Số CT</th>
                    <th><i class="bi bi-calendar3"></i> Ngày</th>
                    <th><i class="bi bi-tag"></i> Loại</th>
                    <th><i class="bi bi-text-left"></i> Diễn giải</th>
                    <th><i class="bi bi-currency-dollar"></i> Tổng tiền</th>
                    <th><i class="bi bi-info-circle"></i> Trạng thái</th>
                    <th><i class="bi bi-gear"></i> Thao tác</th>
                </tr>
            </thead>
            <tbody id="vouchersTableBody">
                <tr>
                    <td colspan="7" class="text-center">Dữ liệu đang tải...</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            loadVouchers();
        });

        function loadVouchers() {
            $('#vouchersTableBody').html('<tr><td colspan="7" class="text-center">Dữ liệu đang tải...</td></tr>');
            // TODO: Call API to load vouchers
        }
    </script>
}