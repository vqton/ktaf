@model AMS.Application.DTOs.CreateChartOfAccountsDto

@{
    ViewData["Title"] = "Thêm tài khoản mới";
}

<div class="page-header">
    <h1 class="page-title">Thêm tài khoản mới</h1>
    <div class="page-actions">
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Quay lại
        </a>
    </div>
</div>

<div class="page-body">
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        
        <div class="row g-4 mb-4">
            <div class="col-md-3">
                <label class="form-label">Mã tài khoản <span class="required">*</span></label>
                <input asp-for="Code" class="form-control font-mono" required>
                <span asp-validation-for="Code" class="text-danger"></span>
            </div>
            <div class="col-md-3">
                <label class="form-label">Tên tài khoản <span class="required">*</span></label>
                <input asp-for="Name" class="form-control" required>
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="col-md-3">
                <label class="form-label">Số tài khoản <span class="required">*</span></label>
                <input asp-for="AccountNumber" type="number" class="form-control" required>
                <span asp-validation-for="AccountNumber" class="text-danger"></span>
            </div>
            <div class="col-md-3">
                <label class="form-label">Loại tài khoản <span class="required">*</span></label>
                <select asp-for="AccountType" class="form-select" required>
                    <option value="">-- Chọn loại --</option>
                    <option value="Asset">Tài sản</option>
                    <option value="Liability">Nợ phải trả</option>
                    <option value="Equity">Vốn chủ sở hữu</option>
                    <option value="Revenue">Doanh thu</option>
                    <option value="Expense">Chi phí</option>
                </select>
                <span asp-validation-for="AccountType" class="text-danger"></span>
            </div>
        </div>
        
        <div class="row g-4 mb-4">
            <div class="col-md-3">
                <label class="form-label">TK cha</label>
                <select asp-for="ParentId" class="form-select select2-accounts">
                    <option value="">Không (TK gốc)</option>
                </select>
            </div>
            <div class="col-md-3">
                <div class="form-check form-switch mt-4">
                    <input asp-for="IsDetail" class="form-check-input" type="checkbox">
                    <label class="form-check-label">TK chi tiết</label>
                </div>
            </div>
            <div class="col-md-3">
                <div class="form-check form-switch mt-4">
                    <input asp-for="IsActive" class="form-check-input" type="checkbox" checked>
                    <label class="form-check-label">Hoạt động</label>
                </div>
            </div>
            <div class="col-md-3">
                <div class="form-check form-switch mt-4">
                    <input asp-for="AllowEntry" class="form-check-input" type="checkbox" checked>
                    <label class="form-check-label">Cho phép nhập</label>
                </div>
            </div>
        </div>
        
        <div class="row g-4 mb-4">
            <div class="col-md-3">
                <label class="form-label">Phân loại thuế</label>
                <input asp-for="TaxCategory" class="form-control">
            </div>
            <div class="col-md-3">
                <label class="form-label">Tài khoản ngân hàng</label>
                <input asp-for="BankAccount" class="form-control">
            </div>
            <div class="col-md-3">
                <label class="form-label">Tên ngân hàng</label>
                <input asp-for="BankName" class="form-control">
            </div>
            <div class="col-md-3">
                <label class="form-label">Số dư đầu kỳ</label>
                <input asp-for="OpeningBalance" class="form-control">
            </div>
        </div>
        
        <div class="row g-4 mb-4">
            <div class="col-md-3">
                <label class="form-label">Mã ngoại tệ</label>
                <input asp-for="CurrencyCode" class="form-control">
            </div>
            <div class="col-md-3">
                <div class="form-check form-switch mt-4">
                    <input asp-for="IsBankAccount" class="form-check-input" type="checkbox">
                    <label class="form-check-label">TK ngân hàng</label>
                </div>
            </div>
            <div class="col-md-3">
                <div class="form-check form-switch mt-4">
                    <input asp-for="IsTaxAccount" class="form-check-input" type="checkbox">
                    <label class="form-check-label">TK thuế</label>
                </div>
            </div>
            <div class="col-md-3">
                <div class="form-check form-switch mt-4">
                    <input asp-for="IsVatAccount" class="form-check-input" type="checkbox">
                    <label class="form-check-label">TK VAT</label>
                </div>
            </div>
        </div>
        
        <div class="row g-4 mb-4">
            <div class="col-md-3">
                <label class="form-label">Mã mức VAT</label>
                <input asp-for="VatRateCode" class="form-control">
            </div>
            <div class="col-md-3">
                <div class="form-check form-switch mt-4">
                    <input asp-for="IsRevenueSharing" class="form-check-input" type="checkbox">
                    <label class="form-check-label">Chia sẻ doanh thu</label>
                </div>
            </div>
            <div class="col-md-3">
                <label class="form-label">% chia sẻ</label>
                <input asp-for="RevenueSharingPercentage" class="form-control">
            </div>
            <div class="col-md-3">
                <label class="form-label">TK đối ứng</label>
                <input asp-for="ReconciliationAccount" class="form-control">
            </div>
        </div>
        
        <div class="d-flex justify-content-end gap-3">
            <button type="button" class="btn btn-outline-secondary" onclick="window.history.back()">Hủy</button>
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-save me-1"></i>Lưu
            </button>
        </div>
    </form>
</div>

@section Scripts {
<script>
    $(function() {
        // Initialize select2 for parent account
        $('.select2-accounts').select2({
            theme: 'bootstrap-5',
            ajax: {
                url: '/ChartOfAccounts/GetActive',
                processResults: function(data) {
                    return {
                        results: data.map(function(item) {
                            return { id: item.id, text: item.code + ' - ' + item.name };
                        })
                    };
                }
            }
        });
    });
</script>
}