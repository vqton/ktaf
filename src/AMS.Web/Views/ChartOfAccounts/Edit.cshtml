@model AMS.Application.DTOs.UpdateChartOfAccountsDto

@{
    ViewData["Title"] = "Sửa tài khoản";
}

<div class="page-header">
    <h1 class="page-title">Sửa tài khoản</h1>
    <div class="page-actions">
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Quay lại
        </a>
        <a asp-action="Details" asp-route-id="@ViewContext.RouteData.Values["id"]" class="btn btn-sm btn-outline-primary">
            <i class="bi bi-eye me-1"></i>Xem chi tiết
        </a>
    </div>
</div>

<div class="page-body">
    <form asp-action="Edit" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" value="@ViewContext.RouteData.Values["id"]" />
        
        <div class="row g-4 mb-4">
            <div class="col-md-3">
                <label class="form-label">Mã tài khoản <span class="required">*</span></label>
                <input asp-for="Code" class="form-control font-mono" required>
                <span asp-validation-for="Code" class="text-danger"></span>
            </div>
            <div class="col-md-3">
                <label class="form-label">Tên tài khoản <span class="required">*</span></label>
                <input asp-for="Name" class="form-control" required>
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="col-md-3">
                <label class="form-label">Số tài khoản <span class="required">*</span></label>
                <input asp-for="AccountNumber" type="number" class="form-control" required>
                <span asp-validation-for="AccountNumber" class="text-danger"></span>
            </div>
            <div class="col-md-3">
                <label class="form-label">Loại tài khoản <span class="required">*</span></label>
                <select asp-for="AccountType" class="form-select" required>
                    <option value="">-- Chọn loại --</option>
                    <option value="Asset">Tài sản</option>
                    <option value="Liability">Nợ phải trả</option>
                    <option value="Equity">Vốn chủ sở hữu</option>
                    <option value="Revenue">Doanh thu</option>
                    <option value="Expense">Chi phí</option>
                </select>
                <span asp-validation-for="AccountType" class="text-danger"></span>
            </div>
        </div>
        
        <div class="row g-4 mb-4">
            <div class="col-md-3">
                <label class="form-label">TK cha</label>
                <select asp-for="ParentId" class="form-select select2-accounts">
                    <option value="">Không (TK gốc)</option>
                </select>
            </div>
            <div class="col-md-3">
                <div class="form-check form-switch mt-4">
                    <input asp-for="IsDetail" class="form-check-input" type="checkbox">
                    <label class="form-check-label">TK chi tiết</label>
                </div>
            </div>
            <div class="col-md-3">
                <div class="form-check form-switch mt-4">
                    <input asp-for="IsActive" class="form-check-input" type="checkbox">
                    <label class="form-check-label">Hoạt động</label>
                </div>
            </div>
            <div class="col-md-3">
                <div class="form-check form-switch mt-4">
                    <input asp-for="AllowEntry" class="form-check-input" type="checkbox">
                    <label class="form-check-label">Cho phép nhập</label>
                </div>
            </div>
        </div>
        
        <div class="row g-4 mb-4">
            <div class="col-md-3">
                <label class="form-label">Phân loại thuế</label>
                <input asp-for="TaxCategory" class="form-control">
            </div>
            <div class="col-md-3">
                <label class="form-label">Tài khoản ngân hàng</label>
                <input asp-for="BankAccount" class="form-control">
            </div>
            <div class="col-md-3">
                <label class="form-label">Tên ngân hàng</label>
                <input asp-for="BankName" class="form-control">
            </div>
            <div class="col-md-3">
                <label class="form-label">Số dư đầu kỳ</label>
                <input asp-for="OpeningBalance" class="form-control">
            </div>
        </div>
        
        <div class="row g-4 mb-4">
            <div class="col-md-3">
                <label class="form-label">Mã ngoại tệ</label>
                <input asp-for="CurrencyCode" class="form-control">
            </div>
            <div class="col-md-3">
                <div class="form-check form-switch mt-4">
                    <input asp-for="IsBankAccount" class="form-check-input" type="checkbox">
                    <label class="form-check-label">TK ngân hàng</label>
                </div>
            </div>
            <div class="col-md-3">
                <div class="form-check form-switch mt-4">
                    <input asp-for="IsTaxAccount" class="form-check-input" type="checkbox">
                    <label class="form-check-label">TK thuế</label>
                </div>
            </div>
            <div class="col-md-3">
                <div class="form-check form-switch mt-4">
                    <input asp-for="IsVatAccount" class="form-check-input" type="checkbox">
                    <label class="form-check-label">TK VAT</label>
                </div>
            </div>
        </div>
        
        <div class="row g-4 mb-4">
            <div class="col-md-3">
                <label class="form-label">Mã mức VAT</label>
                <input asp-for="VatRateCode" class="form-control">
            </div>
            <div class="col-md-3">
                <div class="form-check form-switch mt-4">
                    <input asp-for="IsRevenueSharing" class="form-check-input" type="checkbox">
                    <label class="form-check-label">Chia sẻ doanh thu</label>
                </div>
            </div>
            <div class="col-md-3">
                <label class="form-label">% chia sẻ</label>
                <input asp-for="RevenueSharingPercentage" class="form-control">
            </div>
            <div class="col-md-3">
                <label class="form-label">TK đối ứng</label>
                <input asp-for="ReconciliationAccount" class="form-control">
            </div>
        </div>
        
        <div class="d-flex justify-content-between">
            <button type="button" class="btn btn-outline-danger" onclick="confirmDelete()">
                <i class="bi bi-trash me-1"></i>Xóa
            </button>
            <div class="d-flex gap-3">
                <button type="button" class="btn btn-outline-secondary" onclick="window.history.back()">Hủy</button>
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-save me-1"></i>Lưu
                </button>
            </div>
        </div>
    </form>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Xóa tài khoản</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Bạn có chắc chắn muốn xóa tài khoản này?</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <form asp-action="Delete" asp-controller="ChartOfAccounts" method="post">
                    <input type="hidden" name="id" value="@ViewContext.RouteData.Values["id"]" />
                    <button type="submit" class="btn btn-danger">Xóa</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function confirmDelete() {
        new bootstrap.Modal('#deleteModal').show();
    }

    $(function() {
        // Initialize select2 for parent account
        $('.select2-accounts').select2({
            theme: 'bootstrap-5',
            ajax: {
                url: '/ChartOfAccounts/GetActive',
                processResults: function(data) {
                    return {
                        results: data.map(function(item) {
                            return { id: item.id, text: item.code + ' - ' + item.name };
                        })
                    };
                }
            }
        });
        
        // Pre-select parent account if exists
        var parentId = '@Model.ParentId';
        if (parentId) {
            $.get('/ChartOfAccounts/GetActive', function(data) {
                var parent = data.find(function(item) { return item.id === parentId; });
                if (parent) {
                    var option = new Option(parent.code + ' - ' + parent.name, parent.id, true, true);
                    $('.select2-accounts').append(option).trigger('change');
                }
            });
        }
    });
</script>
}