@{
    Layout = "_Layout";
    ViewData["Title"] = "Trang Chủ";
}

<div class="text-center mb-4">
    <i class="bi bi-calculator text-primary" style="font-size: 4rem;"></i>
    <h1 class="mt-3">Hệ Thống Quản Lý Kế Toán</h1>
    <p class="lead text-muted">Accounting Management System - Version 1.0</p>
</div>

<div class="row g-4">
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body text-center">
                <i class="bi bi-receipt text-primary" style="font-size: 2.5rem;"></i>
                <h5 class="card-title mt-3">Chứng Từ</h5>
                <p class="card-text text-muted">Quản lý chứng từ kế toán</p>
                <a asp-controller="Vouchers" asp-action="Index" class="btn btn-outline-primary">
                    <i class="bi bi-arrow-right me-1"></i> Truy cập
                </a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body text-center">
                <i class="bi bi-graph-up-arrow text-success" style="font-size: 2.5rem;"></i>
                <h5 class="card-title mt-3">Báo Cáo</h5>
                <p class="card-text text-muted">Xem báo cáo tài chính</p>
                <a href="#" class="btn btn-outline-success disabled">
                    <i class="bi bi-arrow-right me-1"></i> Sắp ra mắt
                </a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body text-center">
                <i class="bi bi-box-seam text-warning" style="font-size: 2.5rem;"></i>
                <h5 class="card-title mt-3">Kho Hàng</h5>
                <p class="card-text text-muted">Quản lý vật tư hàng hóa</p>
                <a href="#" class="btn btn-outline-warning disabled">
                    <i class="bi bi-arrow-right me-1"></i> Sắp ra mắt
                </a>
            </div>
        </div>
    </div>
</div>

<div class="mt-5">
    <h5><i class="bi bi-lightning-charge me-2"></i>Thao tác nhanh</h5>
    <div class="d-flex gap-2 mt-3">
        <a asp-controller="Vouchers" asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i> Tạo chứng từ mới
        </a>
    </div>
</div>
