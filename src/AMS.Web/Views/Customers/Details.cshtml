@model AMS.Application.DTOs.CustomerDto

@{
    ViewData["Title"] = "Chi tiết khách hàng";
}

<div class="page-header">
    <h1 class="page-title">Chi tiết khách hàng</h1>
    <div class="page-actions">
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Quay lại
        </a>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-primary">
            <i class="bi bi-pencil me-1"></i>Sửa
        </a>
    </div>
</div>

<div class="page-body">
    <div class="row">
        <div class="col-md-6">
            <div class="acc-card mb-4">
                <div class="acc-card-header">
                    <h5>Thông tin khách hàng</h5>
                </div>
                <div class="acc-card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-4">Mã khách hàng</dt>
                        <dd class="col-sm-8 font-mono fw-semibold">@Model.Code</dd>
                        
                        <dt class="col-sm-4">Tên khách hàng</dt>
                        <dd class="col-sm-8">@Model.Name</dd>
                        
                        <dt class="col-sm-4">Mã số thuế</dt>
                        <dd class="col-sm-8 font-mono">@Model.TaxCode</dd>
                        
                        <dt class="col-sm-4">Địa chỉ</dt>
                        <dd class="col-sm-8">@(Model.Address ?? "—")</dd>
                        
                        <dt class="col-sm-4">Điện thoại</dt>
                        <dd class="col-sm-8">@(Model.Phone ?? "—")</dd>
                        
                        <dt class="col-sm-4">Email</dt>
                        <dd class="col-sm-8">@(Model.Email ?? "—")</dd>
                        
                        <dt class="col-sm-4">Người liên hệ</dt>
                        <dd class="col-sm-8">@(Model.ContactPerson ?? "—")</dd>
                        
                        <dt class="col-sm-4">Tỉnh/TP</dt>
                        <dd class="col-sm-8">@(Model.Province ?? "—")</dd>
                        
                        <dt class="col-sm-4">Quận/Huyện</dt>
                        <dd class="col-sm-8">@(Model.District ?? "—")</dd>
                        
                        <dt class="col-sm-4">Phường/Xã</dt>
                        <dd class="col-sm-8">@(Model.Ward ?? "—")</dd>
                    </dl>
                </div>
            </div>
        </div>
        
        <div class="col-md-6">
            <div class="acc-card mb-4">
                <div class="acc-card-header">
                    <h5>Thông tin tài chính</h5>
                </div>
                <div class="acc-card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-4">Hạn mức nợ</dt>
                        <dd class="col-sm-8 font-mono">@Model.CreditLimit.ToString("N0")</dd>
                        
                        <dt class="col-sm-4">Hạn thanh toán (ngày)</dt>
                        <dd class="col-sm-8">@Model.PaymentTermDays</dd>
                        
                        <dt class="col-sm-4">TK ngân hàng</dt>
                        <dd class="col-sm-8">@(Model.BankAccount ?? "—")</dd>
                        
                        <dt class="col-sm-4">Tên ngân hàng</dt>
                        <dd class="col-sm-8">@(Model.BankName ?? "—")</dd>
                        
                        <dt class="col-sm-4">Người nộp VAT</dt>
                        <dd class="col-sm-8">
                            @if (Model.IsVatPayer)
                            {
                                <i class="bi bi-check-circle text-success"></i>
                            }
                            else
                            {
                                <i class="bi bi-dash"></i>
                            }
                        </dd>
                        
                        <dt class="col-sm-4">Loại hóa đơn</dt>
                        <dd class="col-sm-8">@(Model.InvoiceType ?? "—")</dd>
                        
                        <dt class="col-sm-4">Trạng thái</dt>
                        <dd class="col-sm-8">
                            @if (Model.IsActive)
                            {
                                <span class="badge bg-success">Hoạt động</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Ngừng</span>
                            }
                        </dd>
                    </dl>
                </div>
            </div>
            
            <div class="acc-card mb-4">
                <div class="acc-card-header">
                    <h5>Thông tin hệ thống</h5>
                </div>
                <div class="acc-card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-4">Ngày tạo</dt>
                        <dd class="col-sm-8">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</dd>
                        
                        <dt class="col-sm-4">Người tạo</dt>
                        <dd class="col-sm-8">@(Model.CreatedBy ?? "—")</dd>
                        
                        <dt class="col-sm-4">Ngày sửa</dt>
                        <dd class="col-sm-8">@(Model.ModifiedAt?.ToString("dd/MM/yyyy HH:mm") ?? "—")</dd>
                        
                        <dt class="col-sm-4">Người sửa</dt>
                        <dd class="col-sm-8">@(Model.ModifiedBy ?? "—")</dd>
                    </dl>
                </div>
            </div>
        </div>
    </div>
</div>